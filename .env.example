PORT=3000
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
WATI_API_KEY=Bearer eyJ...
ADMIN_PHONE=593999999999
# Optional: Email of the WATI bot user account — if set, messages from this email are treated as bot replies and ignored
WATI_BOT_EMAIL=bot@yourdomain.com

# ── Zoho CRM integration (Planificación de Entregas) ──────────────────────────
# Generate credentials at: https://api-console.zoho.com/  → Self Client
# Required scopes: ZohoCRM.modules.ALL,ZohoCRM.settings.READ
# Leave blank to disable Zoho integration (bot still works normally)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Regional endpoints — change if your Zoho account is in EU (.eu) or India (.in)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://www.zohoapis.com
# API name of your custom module — verify in Zoho → Settings → Developer Space → APIs → Modules
ZOHO_MODULE_API_NAME=Planificacion_de_Entregas
